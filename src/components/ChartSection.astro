---
import { Image } from 'astro:assets';
import neoflwMark from '../assets/neoflw.png';
import { GECKOTERMINAL_POOL_EMBED_URL } from '../web3/constants';

interface Props {
    locale?: 'en' | 'pt-BR';
}
const { locale = 'pt-BR' } = Astro.props;
const pt = locale === 'pt-BR';
---
<section class="chart-section" id="chart"> 
    <div class="wrap"> 
        <div class="section-eyebrow">{pt ? '02 - Mercado' : '02 - Market'}</div>
        <div class="section-title">{pt ? 'Gráfico de preço ao vivo' : 'Live price chart'}</div>
        <div class="chart-wrap"> 
            <div class="chart-header"> 
                <div class="chart-left"> 
                    <div class="chart-icon"> 
                        <Image src={neoflwMark} alt="NEOFLW" width={32} height={32} loading="lazy" />
                    </div>
                    <div>
                        <div class="chart-info-name">$NEOFLW / ETH</div>
                        <div class="chart-info-sub">Base Mainnet · GeckoTerminal</div>
                    </div>
                </div>
                <div class="chart-header-actions"> 
                    <button
                        id="chart-expand-btn"
                        class="chart-expand-btn"
                        type="button"
                        aria-expanded="false"
                        aria-controls="chart-wrap"
                    >
                        {pt ? 'Expandir' : 'Expand'}
                    </button>
                    <div class="chart-live">{pt ? 'Ao vivo' : 'Live'}</div>
                </div>
            </div>
            <div class="chart-wrap-shell" id="chart-wrap"> 
                <div class="chart-embed"> 
                    <iframe
                        height="100%"
                        width="100%"
                        id="geckoterminal-embed"
                        title="Embed $NEOFLW / ETH 0.3%"
                        src={GECKOTERMINAL_POOL_EMBED_URL}
                        loading="lazy"
                        allow="clipboard-write"
                        allowfullscreen
                    ></iframe>
                </div>
            </div>
        </div>
    </div>
</section>

<script define:vars={{ pt }} is:inline>
    const chartShell = document.getElementById('chart-wrap');
    const expandBtn = document.getElementById('chart-expand-btn');

    if (chartShell && expandBtn) {
        const labels = {
            expand: pt ? 'Expandir' : 'Expand',
            close: pt ? 'Fechar' : 'Close',
        };

        const closeFullscreen = () => {
            chartShell.classList.remove('is-fullscreen');
            document.body.style.overflow = '';
            expandBtn.textContent = labels.expand;
            expandBtn.setAttribute('aria-expanded', 'false');
        };

        const toggleFullscreen = () => {
            const isFullscreen = chartShell.classList.toggle('is-fullscreen');
            document.body.style.overflow = isFullscreen ? 'hidden' : '';
            expandBtn.textContent = isFullscreen ? labels.close : labels.expand;
            expandBtn.setAttribute('aria-expanded', isFullscreen ? 'true' : 'false');
        };

        expandBtn.addEventListener('click', toggleFullscreen);

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && chartShell.classList.contains('is-fullscreen')) {
                closeFullscreen();
            }
        });
    }
</script>
