# ─────────────────────────────────────────────────────────────
# NEØ FlowOFF — Token Page · environment template
#
# Copy to `.env` (local dev) and mirror in Vercel → Project →
# Environment Variables for production. Never commit `.env`.
#
# Variables prefixed with PUBLIC_ are exposed to the browser
# via import.meta.env. Anything else stays server-side only.
# ─────────────────────────────────────────────────────────────

# ── Client / browser (PUBLIC_*) ───────────────────────────────

# CDP API key — also used to derive the Paymaster URL.
# Get it at https://portal.cdp.coinbase.com/
PUBLIC_ONCHAINKIT_API_KEY=

# Base RPC endpoint. CDP RPC is recommended for higher rate limits.
# Format example: https://api.developer.coinbase.com/rpc/v1/base/<KEY>
PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# NEOFLW contract address (Base mainnet)
PUBLIC_CONTRACT_ADDRESS=0x41F4ff3d45DED9C1332e4908F637B75fe83F5d6B

# Pool reference for price/volume queries (GeckoTerminal/DexScreener).
# Accepts two formats:
#   - 0x + 40 hex chars  → EVM pool contract address (Uniswap V2/V3, Aerodrome, etc.)
#   - 0x + 64 hex chars  → pool ID (Uniswap V4 PoolManager singleton — current case)
# Validation runs at build time in src/web3/constants.ts.
PUBLIC_POOL_ADDRESS=0xba6f7f1d429c61e1714bd94a1c74414289fe52f1c14473ba005edfd042d3f014

# Public site URL (used in OG tags / canonical / deep links).
# Production: https://neoflw.xyz (custom domain). The vercel.app alias
# remains active as a preview/mirror, but should NOT be the canonical.
PUBLIC_SITE_URL=https://neoflw.xyz

# Basescan token URL (for explorer links)
PUBLIC_BASESCAN_URL=https://basescan.org/token/0x41f4ff3d45ded9c1332e4908f637b75fe83f5d6b

# Base.dev App ID — required for Builder Rewards attribution
PUBLIC_BASE_APP_ID=


# ── Server-side / integrations ────────────────────────────────

# Turso (libsql) — wallet tracking persistence used by /api/track
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Coinbase Developer Platform — Secret API key (server-side only)
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# Builder code for incentive programs / attribution
BUILDER_CODE=

# Base.dev project metadata (optional, for build info)
BASE_PROJECT_ID=
BASE_BUILD_INFO_URL=
