---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import HeroSection from './HeroSection.astro';
import ProofSection from './ProofSection.astro';
import StatsBar from './StatsBar.astro';
import TokenomicsSection from './TokenomicsSection.astro';
import ChartSection from './ChartSection.astro';
import VerifySection from './VerifySection.astro';
import Footer from './Footer.astro';
import {
  BASESCAN_TOKENSUPPLY_API_URL,
  DEXSCREENER_PAIR_API_URL,
  GECKOTERMINAL_POOL_API_URL,
  MAX_SUPPLY_TOKENS,
  NEOFLW_ADDRESS,
  SITE_URL,
} from '../web3/constants';

interface Props {
  locale?: 'en' | 'pt-BR';
}
const { locale = 'en' } = Astro.props;
const pt = locale === 'pt-BR';
const numberLocale = pt ? 'pt-BR' : 'en-US';
const layoutTitle = pt ? 'NEOFLW - Token NEØ FLOWOFF' : 'NEOFLW - NEØ FLOWOFF Token';
const layoutDescription = pt
  ? 'NEOFLW é o token nativo do ecossistema NEØ FLOWOFF. ERC-20 na Base mainnet.'
  : 'NEOFLW is the native token of the NEØ FLOWOFF ecosystem. ERC-20 on Base mainnet.';
const baseRpcUrl = (import.meta.env.PUBLIC_BASE_RPC_URL || 'https://mainnet.base.org').trim() || 'https://mainnet.base.org';
// Origin sem protocolo — formato esperado por deep links de wallets mobile (MetaMask /dapp/, etc).
const siteHost = SITE_URL.replace(/^https?:\/\//, '').replace(/\/$/, '');
const onchain = {
  contract: NEOFLW_ADDRESS,
  contractLc: NEOFLW_ADDRESS.toLowerCase(),
  maxSupply: MAX_SUPPLY_TOKENS,
  geckoApi: GECKOTERMINAL_POOL_API_URL,
  dexscreenerApi: DEXSCREENER_PAIR_API_URL,
  basescanSupplyApi: BASESCAN_TOKENSUPPLY_API_URL,
};
const i18n = {
  connectWallet: pt ? 'Conectar Wallet' : 'Connect Wallet',
  chooseWallet: pt ? 'Escolha sua wallet' : 'Choose your wallet',
  cancel: pt ? 'Cancelar' : 'Cancel',
  opensMetaMask: pt ? 'Abre o app da MetaMask' : 'Opens MetaMask app',
  opensCoinbase: pt ? 'Abre o app da Coinbase Wallet' : 'Opens Coinbase Wallet app',
  opensUniswap: pt ? 'Abre o app da Uniswap' : 'Opens Uniswap app',
  opensRainbow: pt ? 'Abre o app da Rainbow' : 'Opens Rainbow app',
  alreadyMinted: pt ? 'Mint já realizado' : 'Already Minted',
  mintNow: pt ? 'Mint Agora' : 'Mint Now',
  connectWalletToMint: pt ? 'Conecte a Wallet para Mint' : 'Connect Wallet to Mint',
  mintingDisabled: pt ? 'Mint Desativado' : 'Minting Disabled',
  checkingBalance: pt ? 'Verificando saldo...' : 'Checking Balance...',
  processingTx: pt ? 'Processando transação...' : 'Processing Transaction...',
  waitingConfirmation: pt ? 'Aguardando confirmação...' : 'Waiting Confirmation...',
  success: pt ? '✓ Sucesso!' : '✓ Success!',
  txFailed: pt ? 'Transação falhou. Tente novamente.' : 'Transaction failed. Please try again.',
  rejected: pt ? 'Usuário rejeitou conexão ou assinatura.' : 'User rejected connection or signature.',
  networkError: pt ? 'Erro de rede: confirme que você está na Base Mainnet.' : 'Network error: Please ensure you are on Base Mainnet.',
  installWallet: pt ? 'Instale MetaMask ou outra extensão de wallet Web3.' : 'Please install MetaMask or another Web3 wallet extension.',
  walletNotFound: pt ? 'Wallet Web3 não encontrada. Instale a MetaMask.' : 'Web3 wallet not found. Please install MetaMask.',
  rejectedTx: pt ? 'Usuário rejeitou a transação.' : 'User rejected transaction.',
  lowBalance: pt ? 'Saldo da wallet insuficiente para cobrir Mint Price + Gas.' : 'Wallet balance too low to cover Mint Price + Gas.',
  copied: pt ? '✓ copiado' : '✓ copied',
};
---

<Layout
  title={layoutTitle}
  description={layoutDescription}
  lang={pt ? 'pt-BR' : 'en'}
  ogLocale={pt ? 'pt_BR' : 'en_US'}
  canonicalPath={pt ? '/pt-br/' : '/'}
>
  <Nav locale={locale} />
  <HeroSection locale={locale} />
  <ProofSection locale={locale} />
  <StatsBar locale={locale} />
  <TokenomicsSection locale={locale} />
  <ChartSection locale={locale} />
  <VerifySection locale={locale} />
  <Footer locale={locale} />

  <!-- Wallet selector modal (mobile deep links) -->
  <div id="wallet-modal" style="
    display:none;position:fixed;inset:0;z-index:9999;
    background:rgba(0,0,0,0.75);backdrop-filter:blur(8px);
    align-items:flex-end;justify-content:center;">
    <div style="
      background:#0a0a10;border:1px solid rgba(255,255,255,0.1);
      border-radius:28px 28px 0 0;padding:2rem 1.5rem 2.5rem;
      width:100%;max-width:480px;animation:slideUp 0.3s cubic-bezier(0.2,0.8,0.2,1);">
      <div style="width:40px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;margin:0 auto 1.5rem;"></div>
      <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.45);margin-bottom:0.5rem;">{i18n.connectWallet}</div>
      <div style="font-size:1.1rem;font-weight:700;margin-bottom:1.5rem;">{i18n.chooseWallet}</div>
      <div style="display:flex;flex-direction:column;gap:0.75rem;" id="wallet-options">
        <!-- MetaMask -->
        <button type="button" data-wallet="metamask" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://raw.githubusercontent.com/MetaMask/brand-resources/master/SVG/SVG_MetaMask_Icon_Color.svg"
               width="36" height="36" alt="MetaMask" style="border-radius:8px;flex-shrink:0;" />
          <div>
            <div>MetaMask</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensMetaMask}</div>
          </div>
        </button>
        <!-- Coinbase Wallet -->
        <button type="button" data-wallet="coinbase" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://www.coinbase.com/assets/press/coinbase-mark-white-icon.png"
               width="36" height="36" alt="Coinbase Wallet" style="border-radius:8px;background:#1652f0;flex-shrink:0;padding:4px;" />
          <div>
            <div>Coinbase Wallet</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensCoinbase}</div>
          </div>
        </button>
        <!-- Uniswap Wallet -->
        <button type="button" data-wallet="uniswap" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://app.uniswap.org/favicon.png"
               width="36" height="36" alt="Uniswap Wallet" style="border-radius:8px;flex-shrink:0;" />
          <div>
            <div>Uniswap Wallet</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensUniswap}</div>
          </div>
        </button>
        <!-- Rainbow -->
        <button type="button" data-wallet="rainbow" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://rainbow.me/favicon-192.png"
               width="36" height="36" alt="Rainbow" loading="lazy"
               referrerpolicy="no-referrer" style="border-radius:8px;flex-shrink:0;" />
          <div>
            <div>Rainbow</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensRainbow}</div>
          </div>
        </button>
      </div>
      <button type="button" data-close-wallet-modal style="
        width:100%;margin-top:1rem;padding:0.875rem;border-radius:999px;
        background:transparent;border:1px solid rgba(255,255,255,0.15);
        color:rgba(255,255,255,0.6);font-family:inherit;font-size:0.875rem;
        cursor:pointer;">{i18n.cancel}</button>
    </div>
  </div>
  <style>
    @keyframes slideUp {
      from { transform: translateY(100%); }
      to   { transform: translateY(0); }
    }
    #wallet-modal.open { display: flex !important; }
  </style>

  <!--
    Runtime vars bridge: Astro define:vars só funciona em <script is:inline>,
    então este pequeno bloco apenas injeta window.__NEOFLW antes do módulo
    bundled (viem) rodar. Nenhuma lógica web3 vive aqui.
  -->
  <script define:vars={{ i18n, numberLocale, baseRpcUrl, pt, siteHost, onchain }} is:inline>
    window.__NEOFLW = { i18n, numberLocale, baseRpcUrl, pt, siteHost, onchain };
  </script>

  <!-- Main client logic — bundled module com viem typed (sem CDN externa). -->
  <script>
    import '../scripts/homepage';
  </script>

</Layout>
