{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "trailingSlash": false,
  "cleanUrls": true,
  "env": {
    "PROJECT_NAME": "NEOFLW Token webapp"
  },
  "rewrites": [
    {
      "source": "/((?!public/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
