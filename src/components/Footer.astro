---
import {
    BASESCAN_TOKEN_URL,
    GECKOTERMINAL_POOL_URL,
    SOURCE_REPOS,
    UNISWAP_BUY_URL,
} from '../web3/constants';

interface Props {
    locale?: 'en' | 'pt-BR';
}
const { locale = 'en' } = Astro.props;
const pt = locale === 'pt-BR';
---
<footer class="footer-area">
    <div class="wrap">
        <div class="footer-box">
            <div class="bc-label" style="text-align: center; margin-bottom: 0.75rem;">{pt ? 'Links do Ecossistema' : 'Ecosystem Links'}</div>
            <div class="bc-title" style="text-align: center; margin-bottom: 2rem;">{pt ? 'Entre na rede' : 'Join the network'}</div>
            <div class="links-cluster-footer">
                <a href="https://neoflowoff.agency" class="link-tile-v2" target="_blank" rel="noopener">
                    <span class="link-tile-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                    </span> {pt ? 'Site' : 'Website'}</a>
                <a href={UNISWAP_BUY_URL} class="link-tile-v2" style="border-color:var(--green);color:var(--green);" target="_blank" rel="noopener">
                    <span class="link-tile-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
                    </span> {pt ? 'Comprar $NEOFLW' : 'Buy $NEOFLW'}</a>
                <a href={BASESCAN_TOKEN_URL} class="link-tile-v2" target="_blank" rel="noopener">
                    <span class="link-tile-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 16.5V7.5L12 2.25L3 7.5V16.5L12 21.75L21 16.5ZM12 4.125L18.75 8.25V15.75L12 19.875L5.25 15.75V8.25L12 4.125Z"/></svg>
                    </span>
                    Basescan</a>
                <a href="https://x.com/neoflw_on_chain" class="link-tile-v2" target="_blank" rel="noopener">
                    <span class="link-tile-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.292 19.49h2.039L6.486 3.24H4.298l13.311 17.403z"/></svg>
                    </span> X</a>
                <a href={SOURCE_REPOS.tokenContract} class="link-tile-v2" target="_blank" rel="noopener">
                    <span class="link-tile-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </span> GitHub</a>
                <a href={GECKOTERMINAL_POOL_URL} class="link-tile-v2" target="_blank" rel="noopener">
                    <span class="link-tile-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>
                    </span>
                    GeckoTerminal</a>
            </div>

            <div class="footer-note" style="margin-top: 4rem; text-align: center; color: var(--text-3); font-size: 0.7rem; border-top: 1px solid var(--border); padding-top: 2rem;">
                <div style="font-weight: 900; font-size: 1rem; letter-spacing: -0.02em; margin-bottom: 0.5rem;"><span style="color: var(--pink);">NEØ</span>FLW</div>
                <div style="margin-bottom: 0.25rem;">neoflowoff.eth · neoflowoff.agency · NEØ Flowoff Marketing e Assessoria Digital LTDA</div>
                <div>&copy; 2026 NEØ Protocol. {pt ? 'Todos os direitos reservados.' : 'All rights reserved.'}</div>
                <div style="margin-top: 0.5rem; font-style: italic;">{pt ? 'Código é lei. Expanda até o caos virar protocolo.' : 'Code is law. Expand until chaos becomes protocol.'}</div>
            </div>
        </div>
    </div>
</footer>
