---
import { BASESCAN_TOKEN_CODE_URL } from '../web3/constants';

interface Props {
    locale?: 'en' | 'pt-BR';
}
const { locale = 'en' } = Astro.props;
const pt = locale === 'pt-BR';
---
<!-- NEW INTERACTIVE BENTO GRID FOR PROOF -->
<section class="bento-section" id="proof">
    <div class="wrap">
        <div class="section-eyebrow">{pt ? 'Evidência On-Chain' : 'On-Chain Evidence'}</div>
        <h2 class="section-title">{pt ? 'Integridade do Protocolo' : 'Protocol Integrity'}</h2>

        <div class="bento">
            <!-- Airdrop Interactive Card -->
            <div class="bc bc-w4 airdrop-card">
                <div class="bc-label">{pt ? 'Recompensa da Comunidade' : 'Community Reward'}</div>
                <div class="bc-title">{pt ? 'Siga e Resgate $NEOFLW' : 'Follow & Claim $NEOFLW'}</div>
                <div class="airdrop-step">
                    <div class="step-num active">1</div>
                    <span>{pt ? 'Siga @NEOProtocol no X' : 'Follow @NEOProtocol on X'}</span>
                </div>
                <div class="airdrop-step">
                    <div class="step-num" id="step-2">2</div>
                    <span>{pt ? 'Conecte a Wallet para Verificar' : 'Connect Wallet to Verify'}</span>
                </div>
                <button class="airdrop-btn" id="claim-init" onclick="simulateFollow()">
                    {pt ? 'Conectar e Seguir' : 'Connect & Follow'}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px;"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                </button>
                <div id="claim-status" style="display:none;font-size:0.7rem;text-align:center;color:var(--green-soft);">
                    {pt ? 'Verificando elegibilidade...' : 'Checking eligibility...'}
                </div>
            </div>

            <div class="bc bc-w8 bc-verified">
                <div class="proof-trust-header">
                    <div>
                        <div class="bc-label">{pt ? 'Segurança Operacional' : 'Operational Security'}</div>
                        <div class="bc-title">{pt ? 'Controles On-Chain Reais' : 'Real On-Chain Controls'}</div>
                    </div>
                    <div class="proof-trust-badge">{pt ? 'VERIFICÁVEL' : 'VERIFIABLE'}</div>
                </div>

                <div class="proof-trust-grid">
                    <article class="proof-trust-item">
                        <div class="proof-trust-item-label">{pt ? 'Governança' : 'Governance'}</div>
                        <div class="proof-trust-item-value">
                            <span id="proof-owner-model">{pt ? 'Ownable2Step' : 'Ownable2Step'}</span>
                            <span id="proof-owner-chip" class="proof-live-chip" style="margin-left:0.45rem;">…</span>
                        </div>
                        <p class="proof-trust-item-body">
                            {pt
                                ? 'Administração explícita: funções críticas usam onlyOwner com transferência em duas etapas.'
                                : 'Explicit admin model: critical functions use onlyOwner with two-step ownership transfer.'}
                        </p>
                    </article>

                    <article class="proof-trust-item">
                        <div class="proof-trust-item-label">{pt ? 'Mint Público' : 'Public Mint'}</div>
                        <div class="proof-trust-item-value">
                            <span>{pt ? '1 por Wallet' : '1 per Wallet'}</span>
                            <span id="proof-mint-chip" class="proof-live-chip" style="margin-left:0.45rem;">…</span>
                        </div>
                        <p class="proof-trust-item-body">
                            {pt
                                ? 'Proteção anti-bot via hasPublicMinted + validação de preço e limite máximo de supply.'
                                : 'Anti-bot guard via hasPublicMinted + price check and max supply enforcement.'}
                        </p>
                    </article>

                    <article class="proof-trust-item">
                        <div class="proof-trust-item-label">{pt ? 'Bridge Multichain' : 'Multichain Bridge'}</div>
                        <div class="proof-trust-item-value">{pt ? 'Minter Dedicado' : 'Dedicated Minter'}</div>
                        <p class="proof-trust-item-body">
                            {pt
                                ? 'bridgeMint restrito ao bridgeMinter configurado pelo owner, com bloqueio de mint para zero address.'
                                : 'bridgeMint restricted to owner-configured bridgeMinter, with zero-address mint protection.'}
                        </p>
                        <div class="proof-trust-mono" id="proof-bridge-minter">—</div>
                    </article>

                    <article class="proof-trust-item">
                        <div class="proof-trust-item-label">{pt ? 'Split de Receita' : 'Revenue Split'}</div>
                        <div class="proof-trust-item-value" id="proof-fee-split">5% / 95%</div>
                        <p class="proof-trust-item-body">
                            {pt
                                ? 'withdraw distribui automaticamente 5% para treasury do protocolo e 95% para owner.'
                                : 'withdraw automatically routes 5% to protocol treasury and 95% to owner.'}
                        </p>
                        <div class="proof-trust-mono" id="proof-treasury-address">—</div>
                    </article>
                </div>

                <div class="proof-trust-footer">
                    <div class="proof-rpc-meta">
                        <span id="proof-rpc-chip" class="proof-live-chip">…</span>
                        <span id="proof-rpc-sync" class="proof-rpc-sync">
                            {pt ? 'Última sync: --:--:--' : 'Last sync: --:--:--'}
                        </span>
                    </div>
                    <a
                        href={BASESCAN_TOKEN_CODE_URL}
                        target="_blank"
                        rel="noopener"
                        class="proof-trust-link"
                    >
                        {pt ? 'Auditar no Basescan' : 'Audit on Basescan'}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:12px;height:12px;">
                            <path d="M7 17L17 7M17 7H7M17 7V17" />
                        </svg>
                    </a>
                </div>
            </div>

            <div class="bc bc-w12" style="background:var(--glass);">
                <div class="bc-label">{pt ? 'Estatísticas Ao Vivo' : 'Live Stats'} <span id="stats-status" style="font-size:0.6rem;color:var(--green);margin-left:0.5rem;opacity:0;">● {pt ? 'ao vivo' : 'live'}</span></div>
                <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));gap:var(--fib4);margin-top:var(--fib3);">
                    <div>
                        <div class="stat-cell-label">{pt ? 'Preço do Token' : 'Token Price'}</div>
                        <div class="bc-number-huge" id="stat-price">—</div>
                    </div>
                    <div>
                        <div class="stat-cell-label">{pt ? 'Volume 24h' : '24h Volume'}</div>
                        <div class="bc-number-huge" id="stat-volume">—</div>
                    </div>
                    <div>
                        <div class="stat-cell-label">{pt ? 'Market Cap' : 'Market Cap'}</div>
                        <div class="bc-number-huge pink" id="stat-mcap">—</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script define:vars={{ pt }} is:inline>
    function simulateFollow() {
        const btn = document.getElementById('claim-init');
        const status = document.getElementById('claim-status');
        const step2 = document.getElementById('step-2');

        btn.innerHTML = pt
            ? '<span style="display:flex;align-items:center;gap:8px;"><div class="dot dot-g" style="animation:pulse 1s infinite"></div> Verificando follow...</span>'
            : '<span style="display:flex;align-items:center;gap:8px;"><div class="dot dot-g" style="animation:pulse 1s infinite"></div> Checking Follow...</span>';
        status.style.display = 'block';

        setTimeout(() => {
            step2.classList.add('active');
            btn.innerHTML = pt ? 'Conectando Wallet...' : 'Connecting Wallet...';
            status.innerHTML = pt ? 'Analisando histórico da wallet na Base...' : 'Analyzing wallet history on Base...';

            setTimeout(() => {
                btn.style.background = 'var(--green)';
                btn.innerHTML = pt ? 'Verificado e Elegível' : 'Verified & Eligible';
                status.innerHTML = pt
                    ? '<span style="color:var(--green)">Sucesso! Você pode resgatar 1.000 $NEOFLW</span>'
                    : '<span style="color:var(--green)">Success! You can claim 1,000 $NEOFLW</span>';
            }, 1500);
        }, 1200);
    }
</script>
